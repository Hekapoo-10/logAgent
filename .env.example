# =============================================================================
# LOG ANOMALY MONITORING SYSTEM — Environment Variables
# =============================================================================
# CARA PAKAI:
# 1. Copy file ini: cp .env.example .env
# 2. Isi setiap nilai di bawah dengan nilai yang sesuai
# 3. JANGAN commit file .env ke git (sudah ada di .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# POSTGRESQL DATABASE
# Nilai ini harus sama persis dengan yang ada di docker-compose.yml
# -----------------------------------------------------------------------------
POSTGRES_USER=deepl_user
POSTGRES_PASSWORD=deepl_password        # Ganti dengan password yang kuat
POSTGRES_DB=deepl_fp
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# URL lengkap untuk SQLAlchemy async (dibuat otomatis dari variabel di atas)
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql+asyncpg://deepl_user:deepl_password@localhost:5432/deepl_fp

# -----------------------------------------------------------------------------
# OPENROUTER API (untuk LLM Nemotron)
# Dapatkan di: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# -----------------------------------------------------------------------------
# TELEGRAM BOT
# Cara dapat token:
# 1. Buka Telegram, cari @BotFather
# 2. Ketik /newbot, ikuti instruksi
# 3. Copy token yang diberikan ke sini
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789              # ID chat tujuan notifikasi (bisa pribadi atau grup)

# -----------------------------------------------------------------------------
# ANOMALY DETECTION THRESHOLD
# Log dengan anomaly_score >= nilai ini akan dikirim sebagai alert
# -----------------------------------------------------------------------------
ANOMALY_THRESHOLD=0.069

# -----------------------------------------------------------------------------
# EMBEDDING MODEL
# Model untuk mengubah teks menjadi vektor (dijalankan lokal, tidak perlu API)
# Pilihan: all-MiniLM-L6-v2 (ringan, cepat) atau all-mpnet-base-v2 (lebih akurat)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# FASTAPI APP
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true                          # Set false saat production

# -----------------------------------------------------------------------------
# RAG SETTINGS
# -----------------------------------------------------------------------------
RAG_TOP_K=3                            # Jumlah dokumen yang diambil saat retrieval
RAG_SIMILARITY_THRESHOLD=0.5           # Minimum similarity score untuk retrieval

# RAGAS judge model (evaluasi RAG) — gpt-4o-mini untuk dev, gpt-4o untuk run final
OPENROUTER_JUDGE_MODEL=openai/gpt-4o-mini
